; Copiez ce fichier vers twilio.credentials.ini et renseignez les valeurs.
; Fichier ignore par git.
;
; Console Twilio > Account Info :
;   Account SID = commence par AC (obligatoire pour l URL API)
;   Auth Token  = mot secret du compte
;
; Si vous utilisez une API Key (Cle API + Cle secrete) au lieu du Auth Token :
;   api_key_sid = SKxxxxxxxx...
;   api_key_secret = ...
;   account_sid reste AC... (compte parent)

[twilio]
account_sid = ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
auth_token  = REMPLACEZ_PAR_CONSOLE_TWILIO
from        = whatsapp:+14155238886

; api_key_sid =
; api_key_secret =
