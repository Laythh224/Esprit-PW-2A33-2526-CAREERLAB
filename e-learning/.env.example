# CareerLab — WhatsApp (Twilio). Copier vers e-learning/.env et renseigner le token.
# Clients tunisiens : 8 chiffres → +216… (voir Model/config/whatsapp.php).

# Compte Twilio (Console > Account Info). Le Auth Token reste SECRET — uniquement dans .env local, jamais dans git.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Expéditeur sandbox Twilio WhatsApp (Try it out > Sandbox). En prod : votre numéro / identité WhatsApp approuvée.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Avant les tests : depuis le WhatsApp du destinataire, envoyer le code "join …" indiqué dans la console
# au numéro sandbox (+1 415 523 8886), sinon les messages ne partent pas.

# Optionnel : auth par API Key à la place du Auth Token (le Account SID reste en AC…)
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=

# Optionnel : modèle WhatsApp approuvé (Content Sid). Vide = message libre (Body), adapté au sandbox / fenêtre 24h.
# TWILIO_CONTENT_SID=
