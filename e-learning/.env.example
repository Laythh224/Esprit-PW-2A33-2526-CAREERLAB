# CareerLab — WhatsApp (Twilio). Copier vers e-learning/.env et renseigner TWILIO_AUTH_TOKEN.
# Tunisiens : 8 chiffres formulaire → +216… (voir Model/config/whatsapp.php).

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Expéditeur sandbox Twilio WhatsApp (Try it out). Production : identité WhatsApp approuvée.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Sandbox : le destinataire doit envoyer le code "join …" au numéro sandbox depuis son WhatsApp.

# Optionnel : API Key à la place du Auth Token (garder le meme identifiant compte Twilio pour l URL API)
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=

# Optionnel : modèle approuvé (Content Sid). Vide = Body libre (sandbox / fenêtre 24h).
# TWILIO_CONTENT_SID=
