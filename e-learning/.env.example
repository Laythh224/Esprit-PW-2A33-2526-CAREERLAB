# CareerLab — WhatsApp (Twilio).
# 1. Copier CE fichier vers : e-learning/.env  (le fichier doit s appeler .env, pas .env.example)
# 2. Remplacer ACxxxxxxxx et xxxxxxxx par les VRAIES valeurs : Twilio Console > Account > API keys / credentials.
#    Les lignes ci-dessous sont des EXEMPLES : tant qu il reste "xxxx", aucun WhatsApp ne partira.
# Tunisiens : 8 chiffres formulaire → +216… (voir Model/config/whatsapp.php).

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_token_secret

# Sandbox WhatsApp (Twilio > Messaging > Try WhatsApp) — souvent whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Sandbox : le destinataire doit envoyer le code "join …" au numéro sandbox depuis son WhatsApp.

# Optionnel : API Key à la place du Auth Token (garder le meme identifiant compte Twilio pour l URL API)
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=

# Optionnel : modèle approuvé (Content Sid). Vide = Body libre (sandbox / fenêtre 24h).
# TWILIO_CONTENT_SID=
